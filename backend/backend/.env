# MySQL Database Configuration
# Format: mysql+pymysql://<username>:<password>@<host>/<database_name>
# For MySQL: mysql+pymysql://root:YOUR_ACTUAL_PASSWORD_HERE@localhost/optichain
# We're using SQLite below as a fallback since MySQL access was denied:
DATABASE_URL=sqlite:///optichain.db

# Application Configuration
DEBUG=True
SECRET_KEY=optichain_super_secret_key
